{
  "entities": {
    "Dataset": {
      "title": "Dataset",
      "description": "A collection of scanned survey forms.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the dataset" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this dataset" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "modifiedAt": { "type": "string", "format": "date-time", "description": "Last modification timestamp" },
        "entryCount": { "type": "number", "description": "Number of entries in this dataset" },
        "type": { "type": "string", "enum": ["medical", "smile", "building"], "description": "Icon type for the dataset" }
      },
      "required": ["name", "ownerId", "createdAt", "modifiedAt", "entryCount"]
    },
    "Scan": {
      "title": "Scan",
      "description": "A single scanned survey form entry.",
      "type": "object",
      "properties": {
        "datasetId": { "type": "string", "description": "ID of the parent dataset" },
        "userId": { "type": "string", "description": "UID of the user who performed the scan" },
        "scanId": { "type": "string", "description": "Unique identifier for the scan" },
        "status": { "type": "string", "enum": ["pending", "completed", "conflict"], "description": "Review status" },
        "confidence": { "type": "number", "description": "Overall OCR confidence score" },
        "extractedData": { 
          "type": "object", 
          "description": "The extracted fields and their values",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "age": { "type": "number" },
            "yoga": { "type": "boolean" }
          }
        },
        "imageUrl": { "type": "string", "description": "URL of the scanned image" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["datasetId", "userId", "scanId", "status", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "System activity log entry.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["primary", "tertiary", "outline"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "createdAt"]
    }
  },
  "firestore": {
    "/datasets/{datasetId}": {
      "schema": "Dataset",
      "description": "Collection of survey datasets"
    },
    "/datasets/{datasetId}/scans/{scanId}": {
      "schema": "Scan",
      "description": "Individual scans within a dataset"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "System activity logs"
    }
  }
}
